{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kith",
  "identifier": "net.splazoosh.kith",
  "build": {
    "beforeDevCommand": { "script": "pnpm dev", "cwd": "../../app" },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": { "script": "pnpm build", "cwd": "../../app" },
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kith",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Kith contributors",
    "copyright": "Copyright © 2026 Kith contributors",
    "license": "MIT",
    "licenseFile": "../../LICENSE",
    "shortDescription": "A local-first family-tree desktop app.",
    "longDescription": "Kith is a local-first family-tree desktop app for Windows. Build your family tree offline — no account, no server, no telemetry — with fuzzy genealogical dates, an elegant navigable chart (ancestors, descendants, hourglass, and network), photos and sources, full-text search, single-file HTML export, and GEDCOM import/export. Your data lives in a plain SQLite file you own.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": { "installMode": "currentUser" }
    }
  }
}
